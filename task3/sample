<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Praveen | Java Developer</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body {
            background: #f4f6f8;
            color: #333;
            line-height: 1.6;
        }

        header {
            background: #111827;
            color: #fff;
            padding: 20px 0;
        }

        nav {
            width: 90%;
            margin: auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        nav h1 {
            font-size: 24px;
        }

        nav ul {
            list-style: none;
            display: flex;
        }

        nav ul li {
            margin-left: 20px;
        }

        nav ul li a {
            text-decoration: none;
            color: #fff;
            font-weight: bold;
        }

        nav ul li a:hover {
            color: #38bdf8;
        }

        .hero {
            padding: 80px 20px;
            text-align: center;
            background: linear-gradient(to right, #0f172a, #1e293b);
            color: white;
        }

        .hero h2 {
            font-size: 40px;
            margin-bottom: 10px;
        }

        .hero p {
            font-size: 18px;
            margin-bottom: 20px;
        }

        .btn {
            background: #38bdf8;
            color: #000;
            padding: 12px 25px;
            border-radius: 25px;
            text-decoration: none;
            font-weight: bold;
        }

        section {
            padding: 60px 20px;
            width: 90%;
            margin: auto;
        }

        section h2 {
            text-align: center;
            margin-bottom: 40px;
            font-size: 32px;
        }

        .about p {
            text-align: center;
            max-width: 700px;
            margin: auto;
        }

        .skills {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
        }

        .card {
            background: #fff;
            padding: 25px;
            border-radius: 12px;
            text-align: center;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .projects {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }

        .contact {
            text-align: center;
        }

        .contact p {
            margin-bottom: 10px;
        }

        footer {
            background: #111827;
            color: white;
            text-align: center;
            padding: 15px;
            margin-top: 40px;
        }
    </style>
</head>
<body>

<header>
    <nav>
        <h1>Praveen</h1>
        <ul>
            <li><a href="#home">Home</a></li>
            <li><a href="#about">About</a></li>
            <li><a href="#skills">Skills</a></li>
            <li><a href="#projects">Projects</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>
</header>

<section class="hero" id="home">
    <h2>Hi, I'm Praveen 👋</h2>
    <p>Java Developer | BSc AI & ML Student</p>
    <a href="#contact" class="btn">Contact Me</a>
</section>

<section class="about" id="about">
    <h2>About Me</h2>
    <p>
        I am a passionate Java developer and a BSc Artificial Intelligence & Machine Learning student.
        I enjoy solving real-world problems using logic, data structures, and clean code.
    </p>
</section>

<section id="skills">
    <h2>Skills</h2>
    <div class="skills">
        <div class="card">Java</div>
        <div class="card">Python</div>
        <div class="card">HTML & CSS</div>
        <div class="card">Data Structures</div>
        <div class="card">OOP Concepts</div>
    </div>
</section>

<section id="projects">
    <h2>Projects</h2>
    <div class="projects">
        <div class="card">
            <h3>Password Generator</h3>
            <p>Secure random password generator using Java.</p>
        </div>
        <div class="card">
            <h3>Management System</h3>
            <p>Console-based management software using OOP.</p>
        </div>
        <div class="card">
            <h3>Portfolio Website</h3>
            <p>Responsive website using only HTML and CSS.</p>
        </div>
    </div>
</section>

<section class="contact" id="contact">
    <h2>Contact</h2>
    <p>Email: praveen@example.com</p>
    <p>Location: India</p>
</section>

<footer>
    <p>© 2026 Praveen | Java Developer</p>
</footer>

</body>
</html>
